# Runtime
NODE_ENV="production"
SELF_URL="https://example.mctai.app"

# PostgreSQL. Required for all persistent state.
DATABASE_URL="postgresql://app_user:app_password@postgres.example.internal:5432/app_database?schema=public"

# Admin authentication. Required for /admin routes.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-long-random-password"
ADMIN_SESSION_SECRET="replace-with-at-least-32-random-characters"

# Object storage. Required for product image uploads and private image reads.
# Use these exact variable names; S3_*, AWS_*, TIGRIS_*, STORAGE_*, UPLOAD_*, and BLOB_* aliases are not read.
OBJECT_STORAGE_ACCESS_KEY_ID="example-access-key-id"
OBJECT_STORAGE_SECRET_ACCESS_KEY="example-secret-access-key"
OBJECT_STORAGE_BUCKET="example-private-bucket"
OBJECT_STORAGE_PREFIX="app_alex_0d18_voltmart_afc02b/"
OBJECT_STORAGE_ENDPOINT="https://fly.storage.tigris.dev"
OBJECT_STORAGE_REGION="auto"
OBJECT_STORAGE_FORCE_PATH_STYLE="true"

# myClawTeam auth service. Reserved for platform user auth integrations.
MCTAI_AUTH_URL="https://auth.mctai.app"
MCTAI_AUTH_APP_TOKEN="app_alex-0d18-voltmart-4b3bf1"
MCTAI_AUTH_JWKS_URL="https://auth.mctai.app/.well-known/jwks.json"

# myClawTeam email service. If omitted, order notification email is skipped.
MCTAI_EMAIL_URL="https://email.mctai.app/send"
MCTAI_EMAIL_APP_TOKEN="example-email-app-token"

# Optional legacy origin fallback. Prefer SELF_URL.
# ALLOWED_CORS_ORIGIN="https://example.mctai.app"
